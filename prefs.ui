<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <requires lib="adw" version="1.5" />
  <object class="GtkAdjustment" id="update-time-params">
    <property name="lower">1</property>
    <property name="upper">60</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
  <object class="GtkBox" id="network_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwSwitchRow" id="include-public-ip">
            <property name="title" translatable="yes">Include public IP address</property>
          </object>
        </child>
        <child>
          <object class="AdwComboRow" id="network-speed-format">
            <property name="title" translatable="yes">Format</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">Bytes</item>
                  <item translatable="yes">Bits</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="prefs-container">
    <property name="visible">0</property>
    <property name="margin-start">6</property>
    <property name="margin-end">6</property>
    <property name="margin_top">6</property>
    <property name="margin_bottom">6</property>
    <property name="orientation">vertical</property>
    <property name="spacing">20</property>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">General</property>
        <child>
          <object class="AdwSpinRow" id="update-time">
            <property name="title" translatable="yes">Seconds between updates</property>
            <property name="update_policy">if-valid</property>
            <property name="adjustment">
              <object class="GtkAdjustment">
                <property name="lower">0</property>
                <property name="upper">60</property>
                <property name="value">50</property>
                <property name="page-increment">10</property>
                <property name="step-increment">1</property>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="AdwComboRow" id="position-in-panel">
            <property name="title" translatable="yes">Position in panel</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">Left</item>
                  <item translatable="yes">Center</item>
                  <item translatable="yes">Right</item>
                  <item translatable="yes">Far Left</item>
                  <item translatable="yes">Far Right</item>
                </items>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="use-higher-precision">
            <property name="title" translatable="yes">Use higher precision</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="alphabetize">
            <property name="title" translatable="yes">Alphabetize sensors</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="hide-zeros">
            <property name="title" translatable="yes">Hide zero values</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="fixed-widths">
            <property name="title" translatable="yes">Use fixed widths</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="hide-icons">
            <property name="title" translatable="yes">Hide icons in top bar</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="menu-centered">
            <property name="title" translatable="yes">Menu always centered</property>
          </object>
        </child>
        <child>
          <object class="AdwComboRow" id="icon-style">
            <property name="title" translatable="yes">Icon style</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">Original</item>
                  <item translatable="yes">GNOME</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Sensors</property>
        <child>
          <object class="AdwSwitchRow" id="show-temperature">
            <property name="title" translatable="yes">Monitor temperature</property>
            <child type="suffix">
              <object class="GtkButton" id="temperature-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-voltage">
            <property name="title" translatable="yes">Monitor voltage</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-fan">
            <property name="title" translatable="yes">Monitor fan</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-memory">
            <property name="title" translatable="yes">Monitor memory</property>
            <child type="suffix">
              <object class="GtkButton" id="memory-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-processor">
            <property name="title" translatable="yes">Monitor processor</property>

            <child type="suffix">
              <object class="GtkButton" id="processor-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-system">
            <property name="title" translatable="yes">Monitor system</property>

            <child type="suffix">
              <object class="GtkButton" id="system-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-network">
            <property name="title" translatable="yes">Monitor network</property>

            <child type="suffix">
              <object class="GtkButton" id="network-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-storage">
            <property name="title" translatable="yes">Monitor storage</property>
            <child type="suffix">
              <object class="GtkButton" id="storage-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-battery">
            <property name="title" translatable="yes">Monitor battery</property>
            <child type="suffix">
              <object class="GtkButton" id="battery-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="show-gpu">
            <property name="title" translatable="yes">Monitor GPU (beta)</property>
            <child type="suffix">
              <object class="GtkButton" id="gpu-prefs">
                <property name="receives_default">1</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="icon_name">emblem-system-symbolic</property>
                <style>
                  <class name="circular" />
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <child>
          <object class="GtkLabel">
            <property name="halign">start</property>
            <property name="margin-start">12</property>
            <property name="margin_bottom">12</property>
            <property name="label" translatable="yes">About</property>
            <attributes>
              <attribute name="weight" value="bold"></attribute>
            </attributes>
          </object>
        </child>
        <child>
          <object class="GtkFrame">
            <property name="margin-start">6</property>
            <property name="margin-end">6</property>
            <property name="child">
              <object class="GtkLabel">
                <property name="halign">start</property>
                <property name="valign">baseline</property>
                <property name="margin_top">5</property>
                <property name="margin_bottom">5</property>
                <property name="margin-start">5</property>
                <property name="margin-end">5</property>
                <property name="label" translatable="yes">Feature requests or bugs? Please visit &lt;a href=&quot;https://github.com/corecoding/Vitals/issues&quot;&gt;GitHub&lt;/a&gt;. No warranty, expressed or implied. &lt;a href=&quot;https://corecoding.com/donate.php&quot;&gt;Donate&lt;/a&gt; if you found this useful.</property>
                <property name="use_markup">1</property>
                <property name="wrap">1</property>
                <property name="xalign">0</property>
              </object>
            </property>
            <child type="label_item">
              <placeholder />
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="storage_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwEntryRow" id="storage-path">
            <property name="title" translatable="yes">Path</property>
            <property name="width_chars">24</property>
          </object>
        </child>
        <child>
          <object class="AdwComboRow" id="storage-measurement">
            <property name="title" translatable="yes">Measurement</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">Binary</item>
                  <item translatable="yes">Decimal</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="temperature_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwComboRow" id="unit">
            <property name="title" translatable="yes">Unit</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">°C</item>
                  <item translatable="yes">°F</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="memory_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwComboRow" id="memory-measurement">
            <property name="title" translatable="yes">Measurement</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">Binary</item>
                  <item translatable="yes">Decimal</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="battery_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <property name="selection_mode">none</property>
        <style>
          <class name="boxed-list" />
        </style>
        <child>
          <object class="AdwComboRow" id="battery-slot">
            <property name="title" translatable="yes">Display Battery</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item translatable="yes">BAT0</item>
                  <item translatable="yes">BAT1</item>
                  <item translatable="yes">BAT2</item>
                  <item translatable="yes">BATT</item>
                  <item translatable="yes">CMB0</item>
                  <item translatable="yes">CMB1</item>
                  <item translatable="yes">CMB2</item>
                  <item translatable="yes">macsmc-battery</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="system_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwEntryRow" id="monitor-cmd">
            <property name="title" translatable="yes">Monitor command</property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="processor_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwSwitchRow" id="include-static-info">
            <property name="title" translatable="yes">Include static info</property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkBox" id="gpu_prefs">
    <property name="margin_top">12</property>
    <property name="margin_bottom">12</property>
    <property name="margin_start">12</property>
    <property name="margin_end">12</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkListBox">
        <style>
          <class name="boxed-list" />
        </style>
        <property name="selection_mode">none</property>
        <child>
          <object class="AdwSwitchRow" id="include-static-gpu-info">
            <property name="title" translatable="yes">Include static GPU info</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
